#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# Test Runner Script
# ─────────────────────────────────────────────────────────────
# Usage:
#   script/test                    # Run all tests (local mode)
#   script/test --ci               # Run in CI mode (parallel + XML output)
#   script/test --coverage         # Generate detailed coverage report
#   script/test -v test/models/    # Run specific tests verbosely
#   script/test -k "test_entry"    # Run tests matching pattern
#   script/test --no-cov           # Skip coverage (faster)
# ─────────────────────────────────────────────────────────────
set -e

cd "$(dirname "$0")/.."

# ─────────────────────────────────────────────────────────────
# Colors
# ─────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Check if colors are supported
if [[ ! -t 1 ]] && [[ -z "$FORCE_COLOR" ]]; then
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    CYAN=''
    BOLD=''
    NC=''
fi

# ─────────────────────────────────────────────────────────────
# Helper Functions
# ─────────────────────────────────────────────────────────────
print_header() {
    echo ""
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}${BOLD}              Python App Template TEST SUITE                    ${NC}${CYAN}║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

print_footer_success() {
    echo ""
    echo -e "${GREEN}╔══════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║${NC}${BOLD}${GREEN}                    ✓ ALL TESTS PASSED                           ${NC}${GREEN}║${NC}"
    echo -e "${GREEN}╚══════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

print_footer_failure() {
    echo ""
    echo -e "${RED}╔══════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║${NC}${BOLD}${RED}                    ✗ TESTS FAILED                                ${NC}${RED}║${NC}"
    echo -e "${RED}╚══════════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

print_info() {
    echo -e "${BLUE}→${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

# ─────────────────────────────────────────────────────────────
# Parse Arguments
# ─────────────────────────────────────────────────────────────
PARALLEL="-n auto"
EXTRA_ARGS=""
COVERAGE_ARGS=""
CI_MODE=false
NO_COV=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --ci)
            CI_MODE=true
            EXTRA_ARGS="$EXTRA_ARGS --junitxml=test-results.xml"
            shift
            ;;
        --coverage)
            COVERAGE_ARGS="--cov-report=html:htmlcov --cov-report=xml:coverage.xml"
            shift
            ;;
        --no-cov)
            NO_COV=true
            shift
            ;;
        -v|--verbose)
            EXTRA_ARGS="$EXTRA_ARGS -vv"
            shift
            ;;
        -k)
            EXTRA_ARGS="$EXTRA_ARGS -k $2"
            shift 2
            ;;
        *)
            EXTRA_ARGS="$EXTRA_ARGS $1"
            shift
            ;;
    esac
done

# ─────────────────────────────────────────────────────────────
# Build and Run Command
# ─────────────────────────────────────────────────────────────
print_header

CMD="poetry run pytest"

if [ "$NO_COV" = true ]; then
    CMD="$CMD --no-cov"
fi

if [ -n "$PARALLEL" ]; then
    CMD="$CMD $PARALLEL"
fi

if [ -n "$COVERAGE_ARGS" ]; then
    CMD="$CMD $COVERAGE_ARGS"
fi

if [ -n "$EXTRA_ARGS" ]; then
    CMD="$CMD $EXTRA_ARGS"
fi

print_info "Mode: $([ "$CI_MODE" = true ] && echo 'CI' || echo 'Local')"
print_info "Coverage: $([ "$NO_COV" = true ] && echo 'Disabled' || echo 'Enabled')"
print_info "Parallel: Enabled (-n auto)"
echo ""
print_info "Executing: ${BOLD}$CMD${NC}"
echo ""
echo -e "${CYAN}──────────────────────────────────────────────────────────────────${NC}"
echo ""

# Run tests and capture exit code
set +e
$CMD
EXIT_CODE=$?
set -e

echo ""
echo -e "${CYAN}──────────────────────────────────────────────────────────────────${NC}"

if [ $EXIT_CODE -eq 0 ]; then
    print_footer_success
    if [ "$NO_COV" != true ]; then
        print_success "Coverage HTML report: ${BOLD}htmlcov/index.html${NC}"
    fi
else
    print_footer_failure
fi

exit $EXIT_CODE
